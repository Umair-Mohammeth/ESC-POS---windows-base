<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <!-- SQLite database connection string; databases are stored under Data/ -->
    <add name="POSDb" connectionString="Data Source=Data/pos.db;Version=3;" providerName="System.Data.SQLite" />
  </connectionStrings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
</configuration>